{
  "name": "pichamber",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n \"SERVER,WEB\" -c \"cyan,magenta\" \"bun run dev:server\" \"bun run dev:web\"",
    "dev:web": "bun --filter @pichamber/web dev",
    "dev:server": "bun --filter @pichamber/server dev",
    "build": "bun --filter '*' build",
    "build:web": "bun --filter @pichamber/web build",
    "build:server": "bun --filter @pichamber/server build",
    "test": "bun --filter '*' test",
    "test:unit": "bun --filter @pichamber/web test:unit",
    "type-check": "bun --filter '*' type-check",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@vitest/eslint-plugin": "^1.6.23",
    "@vue/eslint-config-typescript": "^14.9.0",
    "concurrently": "^9.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-oxlint": "~1.73.0",
    "eslint-plugin-vue": "~10.9.2",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.74.0",
    "typescript": "~6.0.0",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "overrides": {
    "vue": "rc",
    "@vue/compiler-core": "rc",
    "@vue/compiler-dom": "rc",
    "@vue/compiler-sfc": "rc",
    "@vue/compiler-ssr": "rc",
    "@vue/compiler-vapor": "rc",
    "@vue/reactivity": "rc",
    "@vue/runtime-core": "rc",
    "@vue/runtime-dom": "rc",
    "@vue/runtime-vapor": "rc",
    "@vue/server-renderer": "rc",
    "@vue/shared": "rc",
    "@vue/compat": "rc"
  }
}
