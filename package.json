{
  "name": "pichamber",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "A browser-based workspace for the Pi Coding Agent",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "serve": "cargo run --release",
    "build:frontend": "tsc -b && vite build",
    "build": "bun run build:frontend && cargo build --release",
    "check": "tsc -b --pretty false && eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:rust": "cargo check",
    "test:rust": "cargo test"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.6",
    "morphdom": "^2.7.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.7",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/morphdom": "^2.4.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14"
}
